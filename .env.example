# Si la Registraduria cambia la URL del portal (nuevo dominio, segunda
# vuelta, etc.), cambia esto -- no hay que tocar el codigo. Dejar vacio usa
# el valor por defecto en src/scraper.py.
PORTAL_URL=

# Azure Blob Storage
AzureWebJobsStorage=
AZURE_STORAGE_CONNECTION_STRING=
# Contenedor por defecto (se puede sobreescribir con --container por ejecucion)
# Valores validos: actas-e14-scraping-1 | actas-e14-scraping-2
AZURE_STORAGE_CONTAINER=actas-e14-scraping-1
